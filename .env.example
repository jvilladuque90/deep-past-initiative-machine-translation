# Copy this file to `.env` and adjust paths for your environment.
# The notebook auto-detects Kaggle / Colab / Local, but these override the defaults.
# NOTE: No API tokens or credentials are required to run this project.

# Directory containing the input CSVs (train.csv, test.csv, lexicon, dictionary, etc.).
# These datasets are licensed/competition data and are NOT included in this repo.
DATA_DIR=./data

# Directory where checkpoints, the merged model, and submission.csv are written.
OUTPUT_DIR=./output

# --- Optional: only if you choose to pull models/data via authenticated APIs ---
# HF_TOKEN=
# KAGGLE_USERNAME=
# KAGGLE_KEY=
